# QuizRoyale Backend Environment Variables
# Copy this to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://quizroyale:quizroyale_dev_2026@localhost:5432/quizroyale

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# Anthropic AI (for question generation)
ANTHROPIC_API_KEY=

# Game Settings
LOBBY_TIMEOUT_SECONDS=20
MIN_PLAYERS=5
MAX_PLAYERS=20
ROUND_COUNT=5

# IAP (In-App Purchase) makbuz doğrulama
# IAP_SANDBOX=true  -> DEV/STUB modu: mağazaya gerçek çağrı yapılmaz (sadece geliştirme)
# IAP_SANDBOX=false -> PRODUCTION: yalnızca gerçek Apple/Google doğrulamalı makbuzlar kabul edilir
# PRODUCTION'DA MUTLAKA false OLMALI.
IAP_SANDBOX=true
# Apple App Store abonelik doğrulama parolası (App Store Connect > App > App-Specific Shared Secret)
# Abonelikler (premium_monthly/yearly) için ZORUNLU.
APPLE_SHARED_SECRET=
# Apple bundle id (opsiyonel ama önerilir; makbuz bundle_id doğrulaması için) örn com.bilyadadus.app
APPLE_BUNDLE_ID=
# Google Play paket adı, örn com.bilyadadus.app
GOOGLE_PACKAGE_NAME=
# Google Play Developer API OAuth2 access token (TODO: service account ile otomatik üret)
GOOGLE_ACCESS_TOKEN=
